{
  "name": "sloth-javascript",
  "version": "0.1.0",
  "description": "Professional Cypress + TypeScript UI test automation framework demonstrating Page Object Model, Allure Reports, and CI/CD integration.",
  "keywords": [
    "cypress",
    "typescript",
    "e2e",
    "test-automation",
    "page-object-model",
    "allure",
    "sdet",
    "qa-automation"
  ],
  "author": "Weipeng Zheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/466725/sloth-javascript.git"
  },
  "bugs": {
    "url": "https://github.com/466725/sloth-javascript/issues"
  },
  "homepage": "https://github.com/466725/sloth-javascript#readme",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "cypress:open": "npx cypress open",
    "cypress:run": "npx cypress run",
    "playwright:test": "npx playwright test playwright/tests/*.spec.ts",
    "playwright:debug": "npx playwright test playwright/tests/*.spec.ts --debug",
    "playwright:allure:generate": "allure generate playwright/allure-results --clean -o playwright/allure-report",
    "playwright:allure:open": "allure open playwright/allure-report",
    "test": "npm run cypress:run",
    "allure:generate": "allure generate cypress/allure-results --clean -o cypress/allure-report",
    "allure:open": "allure open cypress/allure-report"
  },
  "devDependencies": {
    "@bahmutov/cy-grep": "^3.0.0",
    "@playwright/test": "^1.61.1",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@types/node": "^26.1.1",
    "allure-commandline": "^2.38.0",
    "allure-playwright": "^3.10.2",
    "cypress": "^15.12.0",
    "cypress-multi-reporters": "^2.0.5",
    "typescript": "^5.3.0"
  }
}
